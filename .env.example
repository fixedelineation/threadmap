# ThreadMaps — Environment variables
# Copy this to .env.local and fill in your values

# Upstash KV (Vercel serverless storage for encrypted share data)
# Get these from your Vercel project dashboard → Settings → Environment Variables
KV_REST_API_URL=https://your-kv-store.upstash.io
KV_REST_API_TOKEN=your_upstash_token_here
